// PWM LED Control example

#define PWM_Period  							25 // ms

class PWMLED
{
	// all members variables are protected
	pin_name_t m_led_pin;
	DigitalOut m_dig_out;
	Ticker m_ticker;
	uint32_t m_cur_time;
	uint32_t m_on_time;

public:
	PWMLED( pin_name_t t_led_pin ) :
		m_led_pin( t_led_pin ),
		m_dig_out( t_led_pin ),
		m_cur_time( 0 ),
		m_on_time( 0 )
	{
		// attach itself
		m_ticker.attach( &PWMLED::callback_pwm, this, 1 );
	}

	// set brightness in percent
	void set_brightness( uint32_t t_bright_level )
	{
		t_bright_level = std::min( t_bright_level, ( uint32_t ) 100U );

		// calculate On time for LED
		m_on_time = PWM_Period * t_bright_level / 100;
	}

protected:
	// PWM control
	void callback_pwm()
	{
		// time position in period
		if ( m_on_time > 0  && m_on_time >= m_cur_time )
		{ // LED On
			m_dig_out.write( 1 );
		}
		else
		{ // LED Off
			m_dig_out.write( 0 );
		}

		// time period (loop) in range of < 0, PWM_Period )
		m_cur_time = ( m_cur_time + 1 ) % PWM_Period;
	}
};

// PWM Control using buttons
void callback_pwm_control( void *t_arg )
{
	PWMLED *lp_led = ( PWMLED * ) t_arg;

	static uint32_t s_bright_level = 0;

	if ( t_arg == nullptr ) return;

	// button pressed?
	if ( g_but_P3_18.read() == 0 )
	{
		// brightness down
		if ( s_bright_level > 0 )
		{
			s_bright_level--;

			lp_led->set_brightness( s_bright_level );
		}
	}
	// button pressed?
	if ( g_but_P3_19.read() == 0 )
	{
		// brightness up
		if ( s_bright_level < 100 )
		{
			s_bright_level++;

			lp_led->set_brightness( s_bright_level );
		}
	}
}

// **************************************************************************

#define BLINK_TIME			500

uint32_t g_blink_period = BLINK_TIME;
uint32_t g_blink_run = 1;

//! Callback function for LED blinking
void callback_led_blinking()
{
	static int l_ticks = 0;

	// stop blinking?
	if ( g_blink_run == 0 ) return;

	// blinking phase
	if ( l_ticks < g_blink_period / 2 )			// time to switch on or off?
	{
		g_led_P3_16.write( 0 );					// LED Off
	}
	else
	{
		g_led_P3_16.write( 1 );					// LED On
	}

	// time period in loop
	l_ticks++;									// milliseconds counter
	if ( l_ticks >= l_blink_period )			// end of time period?
	{
		l_ticks = 0;							// start time period again
	}
}

